generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") 
}

// --- Authentication & RBAC ---

model User {
  id           String               @id @default(uuid())
  email        String               @unique
  passwordHash String
  name         String?
  memberships  OrganizationMember[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

enum Role {
  ADMIN
  MEMBER
}

model Organization {
  id          String               @id @default(uuid())
  name        String
  slug        String               @unique
  members     OrganizationMember[]
  projects    Project[]
  invitations Invitation[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

// Junction table mapping Users to Organizations with a specific Role
model OrganizationMember {
  id             String @id @default(uuid())
  userId         String
  organizationId String
  role           Role   @default(MEMBER)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

// --- Multi-Tenancy Hierarchy ---

model Project {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  incidents      Incident[]
  traces         Trace[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  ingestKey      String    @default(uuid()) @unique
}

// --- Core Data ---

model Incident {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      String     @default("open")
  severity    String     @default("high")
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  events      LogEvent[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model LogEvent {
  id            String   @id @default(uuid())
  timestamp     DateTime
  level         String
  message       String
  service       String?
  correlationId String?
  incidentId    String
  incident      Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  traceRefId String?
  trace      Trace?  @relation(fields: [traceRefId], references: [id], onDelete: SetNull)

  spanRefId String?
  span      Span?   @relation("SpanLogEvents", fields: [spanRefId], references: [id], onDelete: SetNull)

  @@index([incidentId])
  @@index([correlationId])
  @@index([traceRefId])
  @@index([spanRefId])
}

model Trace {
  id            String     @id @default(uuid())
  traceId       String     @unique
  projectId     String
  project       Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rootService   String?
  rootOperation String?
  status        String?
  startedAt     DateTime
  endedAt       DateTime?
  spans         Span[]
  logEvents     LogEvent[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([projectId])
  @@index([startedAt])
  @@index([status])
}

model Span {
  id            String     @id @default(uuid())
  spanId        String     @unique
  parentSpanId  String?
  traceRefId    String
  trace         Trace      @relation(fields: [traceRefId], references: [id], onDelete: Cascade)
  serviceName   String
  operationName String
  status        String?
  errorMessage  String?
  startTime     DateTime
  endTime       DateTime?
  durationMs    Int?
  logEvents     LogEvent[] @relation("SpanLogEvents")
  createdAt     DateTime   @default(now())

  @@index([traceRefId])
  @@index([parentSpanId])
  @@index([serviceName])
  @@index([operationName])
  @@index([status])
}

model Invitation {
  id             String       @id @default(uuid())
  email          String
  organizationId String
  token          String       @unique
  role           Role         @default(MEMBER)
  expiresAt      DateTime
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([email, organizationId])
  @@index([token])
}
